NEXUS_HOST=nexus.example.com
NEXUS_PORT=443
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=SuperSecret456

# HTTPS Certificates
NEXUS_SSL_CERT_PATH=/etc/nexus/ssl/nexus.crt
NEXUS_SSL_KEY_PATH=/etc/nexus/ssl/nexus.key

# NFS Storage
NEXUS_NFS_DATA=/nexus/data

# LDAP Integration
LDAP_ENABLED=true
LDAP_HOST=ldap.example.com
LDAP_PORT=389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=SuperSecretLDAP
LDAP_BASE=dc=example,dc=com
LDAP_USER_ATTRIBUTE=uid
