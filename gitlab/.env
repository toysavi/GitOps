# GitLab EE Settings
GITLAB_HOST=gitlab.example.com
GITLAB_HTTP_PORT=80
GITLAB_HTTPS_PORT=443
GITLAB_SSH_PORT=2222
GITLAB_ROOT_PASSWORD=SuperSecret123

# SSL Certificates
GITLAB_SSL_CERT_PATH=/gitlab/deployment/ssl/gitlab.example.com.crt
GITLAB_SSL_KEY_PATH=/gitlab/deployment/ssl/gitlab.example.com.key

# NFS Storage Paths
GITLAB_NFS_CONFIG=/gitlab/config
GITLAB_NFS_LOGS=/gitlab/logs
GITLAB_NFS_DATA=/gitlab/data

# LDAP Settings
LDAP_ENABLED=true
LDAP_HOST=ldap.example.com
LDAP_PORT=389
LDAP_UID=uid
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=SuperSecretLDAP
LDAP_BASE=dc=example,dc=com
