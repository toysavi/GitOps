# ArgoCD
ARGOCD_HOST=argocd.example.com
ARGOCD_ADMIN_PASSWORD=SuperSecretArgo
ARGOCD_SSL_CERT_PATH=/argo-cd/ssl/argocd.crt
ARGOCD_SSL_KEY_PATH=/argo-cd/ssl/argocd.key
ARGOCD_NFS_DATA=/argo-cd/data

# Monitoring
PROMETHEUS_HOST=prometheus.example.com
GRAFANA_HOST=grafana.example.com
ALERTMANAGER_HOST=alertmanager.example.com
PROMETHEUS_NFS_DATA=/argo-cd/prometheus/data
GRAFANA_NFS_DATA=/argo-cd/grafana/data
ALERTMANAGER_NFS_DATA=/argo-cd/alertmanager/data
